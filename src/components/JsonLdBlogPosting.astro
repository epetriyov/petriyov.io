---
import type { CollectionEntry } from 'astro:content';
import { SITE, canonicalUrl } from '../config/site';

interface Props {
  post: CollectionEntry<'blog'>;
  ogImage: string;
}

const { post, ogImage } = Astro.props;
const url = canonicalUrl(`/blog/${post.id}/`);

const blogPosting = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  inLanguage: post.data.lang,
  keywords: post.data.tags.join(', '),
  image: new URL(ogImage, SITE.url).href,
  url,
  mainEntityOfPage: url,
  author: {
    '@type': 'Person',
    name: SITE.lastName,
    alternateName: SITE.lastNameEn,
    url: SITE.url,
  },
};

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Главная', item: SITE.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'Блог', item: canonicalUrl('/blog/') },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: url },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(blogPosting)} is:inline />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} is:inline />
