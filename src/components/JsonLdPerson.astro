---
import { getImage } from 'astro:assets';
import { SITE } from '../config/site';
import avatarSrc from '../assets/avatar.jpg';

const avatar = await getImage({ src: avatarSrc, width: 512, height: 512, format: 'jpeg' });

const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.lastName,
  alternateName: [SITE.lastNameEn, SITE.name, SITE.nameEn],
  givenName: 'Евгений',
  familyName: SITE.lastName,
  jobTitle: SITE.jobTitles,
  knowsAbout: SITE.knowsAbout,
  email: `mailto:${SITE.email}`,
  url: SITE.url,
  image: new URL(avatar.src, SITE.url).href,
  sameAs: [SITE.social.github, SITE.social.linkedin, SITE.social.telegram],
};
---

<script type="application/ld+json" set:html={JSON.stringify(person)} is:inline />
