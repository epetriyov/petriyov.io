---
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TOC from '../../components/TOC.astro';
import PrevNext from '../../components/PrevNext.astro';
import JsonLdBlogPosting from '../../components/JsonLdBlogPosting.astro';
import { formatDate, isoDate, readingTimeLabel } from '../../lib/format';

export const getStaticPaths = (async () => {
  // по возрастанию даты: prev — более старая статья, next — более новая
  const posts = (await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft)).sort(
    (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
  );
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: { post, prev: posts[i - 1], next: posts[i + 1] },
  }));
}) satisfies GetStaticPaths;

const { post, prev, next } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(post);
const minutes = remarkPluginFrontmatter.minutesRead as number;
const ogImage = `/og/${post.id}.png`;
---

<Base
  title={`${post.data.title} — Петриёв`}
  description={post.data.description}
  lang={post.data.lang}
  ogImage={ogImage}
  ogType="article"
>
  <JsonLdBlogPosting slot="head" post={post} ogImage={ogImage} />

  <article>
    <header class="mb-8">
      <h1 class="text-[32px] font-[650] leading-[1.25] tracking-[-0.015em]">{post.data.title}</h1>
      <p class="mt-3.5 flex flex-wrap items-baseline gap-x-2 gap-y-1 text-[13.5px] text-faint">
        <time datetime={isoDate(post.data.pubDate)} class="tabular-nums">{formatDate(post.data.pubDate, post.data.lang)}</time>
        <span aria-hidden="true">·</span>
        <span>{readingTimeLabel(minutes, post.data.lang)}</span>
        {
          post.data.tags.length > 0 && (
            <>
              <span aria-hidden="true">·</span>
              {post.data.tags.map((tag) => (
                <a href={`/blog/tags/${tag}/`} class="text-faint no-underline transition-colors hover:text-accent">
                  #{tag}
                </a>
              ))}
            </>
          )
        }
      </p>
      {
        post.data.updatedDate && (
          <p class="mt-1 text-[13px] text-faint">
            Обновлено: <time datetime={isoDate(post.data.updatedDate)}>{formatDate(post.data.updatedDate, post.data.lang)}</time>
          </p>
        )
      }
    </header>

    <TOC headings={headings} />

    <div class="prose">
      <Content />
    </div>
  </article>

  <PrevNext prev={prev} next={next} />
</Base>
