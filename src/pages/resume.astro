---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';

const resume = await getEntry('resume', 'main');
if (!resume) throw new Error('Не найден src/content/resume.yaml');
const { role, summary, experience, skills, education } = resume.data;
---

<Base
  title="Резюме — Евгений Петриёв, Engineering Manager"
  description="Резюме Евгения Петриёва (Petriyov): опыт руководства разработкой IoT-платформ, навыки, образование. PDF-версия доступна для скачивания."
>
  <div class="flex items-start justify-between gap-5 max-[540px]:flex-col">
    <div>
      <h1 class="text-[27px] font-[650] tracking-[-0.015em]">Резюме</h1>
      <p class="mt-1.5 text-[15px] text-muted">{role}</p>
    </div>
    <a
      href="/petriyov-cv.pdf"
      download
      class="flex-none rounded-lg bg-accent px-4 py-2 text-[14px] font-[550] text-white no-underline shadow-card transition-opacity hover:opacity-90"
    >
      Скачать PDF
    </a>
  </div>

  <p class="mt-5 leading-[1.7] text-ink-soft">{summary}</p>

  <h2 class="section-label mb-4 mt-11">Опыт</h2>
  <ol class="relative ml-1 space-y-7 border-l border-line pl-6">
    {
      experience.map((job) => (
        <li class="relative">
          <span class="absolute -left-[29px] top-2 h-[7px] w-[7px] rounded-full bg-accent" aria-hidden="true" />
          <div class="flex items-baseline justify-between gap-4 max-[480px]:flex-col max-[480px]:gap-0.5">
            <h3 class="text-[16.5px] font-semibold leading-[1.35]">{job.title}</h3>
            <span class="whitespace-nowrap text-[13px] tabular-nums text-faint">
              {job.start}—{job.end ?? 'сейчас'}
            </span>
          </div>
          <div class="mt-0.5 text-[14px] text-muted">
            {job.company}
            {job.location && <span class="text-faint"> · {job.location}</span>}
          </div>
          {job.points.length > 0 && (
            <ul class="mt-2.5 space-y-1.5 text-[14.5px] leading-[1.6] text-ink-soft">
              {job.points.map((point) => (
                <li class="flex gap-2">
                  <span class="text-faint" aria-hidden="true">
                    —
                  </span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))
    }
  </ol>

  <h2 class="section-label mb-4 mt-11">Навыки</h2>
  <div class="space-y-4">
    {
      skills.map((group) => (
        <div class="flex items-baseline gap-4 max-[480px]:flex-col max-[480px]:gap-1">
          <span class="w-32 flex-none text-[13.5px] font-[550] text-muted">{group.group}</span>
          <ul class="flex flex-wrap gap-1.5">
            {group.items.map((skill) => (
              <li class="rounded-full border border-line bg-surface px-3 py-1 text-[13px] text-ink-soft">{skill}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <h2 class="section-label mb-4 mt-11">Образование</h2>
  <ul class="space-y-4">
    {
      education.map((edu) => (
        <li class="flex items-baseline justify-between gap-4 max-[480px]:flex-col max-[480px]:gap-0.5">
          <div>
            <div class="text-[15.5px] font-semibold">{edu.place}</div>
            <div class="mt-0.5 text-[14px] text-muted">{edu.degree}</div>
          </div>
          <span class="whitespace-nowrap text-[13px] tabular-nums text-faint">
            {edu.start}
            {edu.end && `—${edu.end}`}
          </span>
        </li>
      ))
    }
  </ul>
</Base>
